{
  "manifest_version": 3,
  "name": "SkillBridge Quick Match",
  "version": "1.0",
  "description": "Analyze and match jobs directly from LinkedIn and Indeed.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*", "*://*.indeed.com/*", "*://*.glassdoor.com/*", "*://*.greenhouse.io/*", "*://*.lever.co/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "host_permissions": [
    "https://api.groq.com/*",
    "http://localhost:5173/*"
  ]
}
